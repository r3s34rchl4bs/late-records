<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LATE RECORDS</title>
<meta name="description" content="Curated vinyl records.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="../style.css">
<style>

/* (ALL YOUR CSS — UNCHANGED) */

</style>
</head>
<body>

<header class="fixed-header">
  <div class="header-inner">
    <a href="../index.html">
      <img src="../images/late-records-logo.png" class="header-logo" alt="LATE RECORDS">
    </a>
    <a href="../cart.html" class="cart-link">Cart (<span class="cart-count">0</span>)</a>
  </div>
</header>

<div class="container" id="mainContainer"></div>

<script src="../script.js"></script>
<script>

const ALBUM_ID   = new URLSearchParams(location.search).get('id') || '';
const AUDIO_BASE = '../audio/';

function renderNotFound() {
  document.getElementById('mainContainer').innerHTML = `
    <div style="padding:80px 0;text-align:center;">
      <h2 style="font-size:22px;margin:0 0 12px;color:#1a1a14;">Album not found</h2>
      <p style="color:rgba(26,26,20,.5);margin:0 0 24px;font-size:13px;">We couldn't find that record.</p>
      <a href="../index.html" style="font-size:11px;text-transform:uppercase;letter-spacing:.08em;text-decoration:underline;color:#1a1a14;">← Back to shop</a>
    </div>
  `;
}

function scoreRelated(cur, cand) {
  let s = 0;
  const cg = LR.ui.splitPipe(cur.genre);
  const cc = LR.ui.splitPipe(cur.context);
  LR.ui.splitPipe(cand.genre).forEach(t   => { if (cg.includes(t)) s += 3; });
  LR.ui.splitPipe(cand.context).forEach(t => { if (cc.includes(t)) s += 2; });
  return s;
}

function renderAlbum(item, all) {
  const sold    = item.status !== 'available';
  const tracks  = LR.ui.splitPipe(item.tracklist);
  const related = all
    .filter(i => i.album_id !== item.album_id)
    .map(i => ({ i, s: scoreRelated(item, i) }))
    .sort((a, b) => b.s - a.s)
    .slice(0, 4);

  document.title = `${item.title} — LATE RECORDS`;

  document.getElementById('mainContainer').innerHTML = `
    <div class="album-page">
      <div class="album-image-wrap">
        <img src="/images/${item.album_id}.jpg" class="album-image" id="albumImg" alt="${item.title}"
          onerror="this.style.display='none';document.getElementById('albumPlaceholder').style.display='flex';">
        <div id="albumPlaceholder" class="album-placeholder" style="display:none;">
          <div class="album-placeholder-inner">
            <svg viewBox="0 0 80 80" class="placeholder-vinyl" xmlns="http://www.w3.org/2000/svg">
              <circle cx="40" cy="40" r="38" fill="none" stroke="rgba(26,26,20,.15)" stroke-width="1"/>
              <circle cx="40" cy="40" r="30" fill="none" stroke="rgba(26,26,20,.1)" stroke-width="1"/>
              <circle cx="40" cy="40" r="22" fill="none" stroke="rgba(26,26,20,.1)" stroke-width="1"/>
              <circle cx="40" cy="40" r="14" fill="none" stroke="rgba(26,26,20,.1)" stroke-width="1"/>
              <circle cx="40" cy="40" r="6" fill="none" stroke="rgba(26,26,20,.2)" stroke-width="1"/>
              <circle cx="40" cy="40" r="2.5" fill="rgba(26,26,20,.25)"/>
            </svg>
            <span class="placeholder-label">Image Pending</span>
          </div>
        </div>
      </div>
      <div class="album-details">
        <div>
          <h1 class="album-title">${item.title}</h1>
          <p class="album-artist">by ${item.artist}</p>
          <div class="album-genre-tags">
            <span class="album-format-label">${(item.format || 'LP').trim()}</span>
            <span class="album-meta-divider"></span>
            ${LR.ui.splitPipe(item.genre).slice(0, 2).map(g =>
              `<a class="album-genre-tag" href="../genre.html?g=${encodeURIComponent(g.toLowerCase())}">${g}</a>`
            ).join('')}
          </div>
        </div>
        <div class="price-block">
          <div class="price-label">Price</div>
          <div class="album-price">${sold
            ? `<span style="color:rgba(26,26,20,.3);text-decoration:line-through;">${LR.ui.peso(item.price)}</span>`
            : LR.ui.peso(item.price)}</div>
          <button class="add-to-cart-btn" id="addToCartBtn"
            data-id="${item.album_id}" data-title="${item.title}"
            data-artist="${item.artist}" data-price="${item.price}"
            data-stock="${item.stock}" ${sold ? 'disabled' : ''}>
            ${sold ? 'Sold Out' : 'Add to Cart'}
          </button>
          <span class="cart-confirm" id="cartConfirm">✓ Added</span>
        </div>
        ${item.description ? `
        <div class="description-block">
          <div style="display:flex;align-items:flex-end;gap:0;">
            <p class="description" id="albumDesc" style="flex:1;">${item.description}</p>
            <button class="description-toggle" id="descToggle" style="display:none;">+</button>
          </div>
        </div>` : ''}
        ${tracks.length ? `
        <div class="tracklist-block">
          <p class="block-heading">Tracklist</p>
          <ul class="tracklist${tracks.length >= 6 ? ' two-col' : ''}">${tracks.map(t => `<li>${t}</li>`).join('')}</ul>
        </div>` : ''}
      </div>
    </div>
    ${related.length ? `
    <section class="related-section">
      <h3 class="related-title">Recommended</h3>
      <div class="related-grid">
        ${related.map(({ i }) => `
          <a class="related-card" href="album.html?id=${i.album_id}">
            <img src="/images/${i.album_id}.jpg" class="related-cover" alt="${i.title}" loading="lazy"
              onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
            <div class="related-placeholder" style="display:none;"></div>
            <div class="related-info">
              <p class="related-name">${i.title}</p>
              <p class="related-artist">${i.artist}</p>
            </div>
          </a>
        `).join('')}
      </div>
    </section>` : ''}
  `;
}

(async () => {
  if (!ALBUM_ID) { renderNotFound(); return; }
  try {
    const album = await LR.api.album(ALBUM_ID);
    if (!album) { renderNotFound(); return; }
    const all = await LR.api.catalog().catch(() => []);
    renderAlbum(album, all);
  } catch (e) {
    renderNotFound();
  }
})();

</script>
<script src="../under-construction.js"></script>
</body>
</html>